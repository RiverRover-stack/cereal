# Copy to `.env` and adjust. `.env` is gitignored; this file is not.

# Base URL of the FastAPI backend (see backend/README.md).
# Only `PUBLIC_`-prefixed vars reach the browser, and they are inlined at build
# time — change this and rebuild, restarting alone will not pick it up.
# Defaults to http://localhost:8000 when unset.
PUBLIC_API_URL=http://localhost:8000
